# ================= RealtyLT — CONNECTION / CREDENTIALS AREA (brief §4) =================
# OWNER FILLS THIS IN. Copy to .env (git-ignored) and paste values — never commit real keys.

# --- MLS / IDX (OneKey MLS via MLS Grid) — powers search, listings, top areas ---
MLS_API_KEY=            # <<< OWNER PASTES MLS/IDX API KEY HERE >>>
MLS_API_ENDPOINT=       # <<< MLS/IDX feed base URL (MLS Grid) >>>
MLS_FEED_ID=            # <<< MLS board / feed identifier (live site used mlsId=280) >>>

# --- MLS replication store (Round 2) — the site reads listings from Vercel Blob ---
BLOB_READ_WRITE_TOKEN=  # <<< auto-set by `vercel blob create-store` / env pull >>>
CRON_SECRET=            # <<< random secret; Vercel Cron sends it as the Bearer auth of /api/cron/sync-mls >>>
# MLS_PHOTO_BUDGET=150  # optional: photos replicated to Blob per sync run (media CDN budget guard)

# --- CRM lead intake (app.realtylt.com) — every form POSTs here ---
CRM_LEAD_WEBHOOK=       # <<< lead-intake endpoint / webhook URL >>>
CRM_API_TOKEN=          # <<< CRM auth token, if required >>>

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://realtylt.com

# Notes:
# - Leave MLS_* empty → site runs on the realistic sample-data fixture.
# - Leave CRM_LEAD_WEBHOOK empty → leads are logged locally (stub mode), not delivered.
# - Use the TEST MLS key to verify the feed, then swap in PRODUCTION at launch and rotate the test key.
